#   0x02227b8f5a9636e895607edd3185ed6ee5598ff7  (HorizonSplendidView)
#   0xc2e7800b5af46e6093872b177b7a5e7f0563be51  (beachboy4)
#   0x37c1874a60d348903594a96703e0507c518fc53a  (CemeterySun)
#   0xd106952ebf30a3125affd8a23b6c1f30c35fc79c  (Herdonia)
TRADER_WALLETS=0xf195721ad850377c96cd634457c70cd9e8308057,0xa8e089ade142c95538e06196e09c85681112ad50,0x492442eab586f242b53bda933fd5de859c8a3782,0xead152b855effa6b5b5837f53b24c0756830c76a,0x02227b8f5a9636e895607edd3185ed6ee5598ff7,0xc2e7800b5af46e6093872b177b7a5e7f0563be51,0x37c1874a60d348903594a96703e0507c518fc53a,0xd106952ebf30a3125affd8a23b6c1f30c35fc79c

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# === ESTRATEGIA ===
CAPITAL_PER_TRADE_USD=5.0
MAX_TOTAL_EXPOSURE_USD=100.0
MAX_DAILY_LOSS_USD=20.0
MIN_MARKET_VOLUME_USD=5000.0
MIN_PROBABILITY=0.30
MAX_PROBABILITY=0.75
MAX_TRADE_AGE_MINUTES=60
TAKE_PROFIT_PCT=0.20
SLIPPAGE_TOLERANCE=0.02

# === COPY SIZING ===
# Modos: fixed | proportional | portfolio | kelly
COPY_SIZE_MODE=fixed
# Para proportional: porcentagem do trade do trader (0.01 = 1%)
COPY_SIZE_MULTIPLIER=0.01
# Teto maximo por trade copiado
MAX_COPY_TRADE_USD=25.0
# Para kelly: fracao do Kelly (0.25 = quarter-Kelly, conservador)
KELLY_FRACTION=0.25

# === MERCADOS ===
# Categorias permitidas: all | sports,crypto,politics (comma-separated)
MARKET_CATEGORIES=all
# Copiar SELL (fechar posicao quando trader vende)
COPY_SELL=true

# === CONFLUENCIA ===
CONFLUENCE_ENABLED=true
# Multiplicador de tamanho quando 2+ traders concordam
CONFLUENCE_BOOST_MODERATE=1.5
CONFLUENCE_BOOST_STRONG=2.0

# === OPERACAO ===
DRY_RUN=true
POLL_INTERVAL_SECONDS=5
POSITION_CHECK_INTERVAL_SECONDS=60
LOG_LEVEL=INFO
